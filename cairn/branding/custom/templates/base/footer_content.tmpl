{{/* Cairn override of templates/base/footer_content.tmpl.

  Always shows "Powered by Forgejo" attribution (per Cairn fork licence),
  alongside Cairn version + page render time. The language switcher and
  licences/swagger links from upstream are preserved.
*/}}
<footer class="page-footer" role="group" aria-label="{{ctx.Locale.Tr "aria.footer"}}">
	<div class="left-links cairn-footer-attribution" role="contentinfo" aria-label="{{ctx.Locale.Tr "aria.footer.software"}}">
		<span>Cairn</span>
		{{if (or .ShowFooterVersion .PageIsAdmin)}}
			<span>·</span>
			{{ctx.Locale.Tr "version"}}:
			{{if .IsAdmin}}
				<a href="{{AppSubUrl}}/admin/config">{{AppVerNoMetadata}}</a>
			{{else}}
				{{AppVerNoMetadata}}
			{{end}}
		{{end}}
		<span>·</span>
		<a target="_blank" rel="noopener noreferrer" href="https://forgejo.org">{{ctx.Locale.Tr "powered_by" "Forgejo"}}</a>
		{{if and .TemplateLoadTimes ShowFooterTemplateLoadTime}}
			<span>·</span>
			{{ctx.Locale.Tr "page"}}: <strong>{{LoadTimes .PageStartTime}}</strong>
		{{end}}
	</div>
	<div class="right-links" role="group" aria-label="{{ctx.Locale.Tr "aria.footer.links"}}">
		<div class="ui dropdown upward language">
			<span class="flex-text-inline">{{svg "octicon-globe" 14}} {{ctx.Locale.LangName}}</span>
			<div class="menu language-menu">
				{{range .AllLangs}}
					<a lang="{{.Lang}}" data-url="{{AppSubUrl}}/?lang={{.Lang}}" class="item {{if eq ctx.Locale.Lang .Lang}}active selected{{end}}">{{.Name}}</a>
				{{end}}
			</div>
		</div>
		<a href="{{AssetUrlPrefix}}/licenses.txt">{{ctx.Locale.Tr "licenses"}}</a>
		{{if .EnableSwagger}}<a href="{{AppSubUrl}}/api/swagger">API</a>{{end}}
		{{template "custom/extra_links_footer" .}}
	</div>
</footer>
