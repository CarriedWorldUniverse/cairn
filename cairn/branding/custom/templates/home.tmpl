{{template "base/head" .}}
<div role="main" aria-label="{{ctx.Locale.Tr "home"}}" class="page-content home">
	<div class="cairn-home">
		<aside class="cairn-home__brand">
			<div class="cairn-home__mark-row">
				<img class="cairn-home__mark" src="{{AssetUrlPrefix}}/img/logo.svg" alt="" aria-hidden="true">
				<span class="cairn-home__wordmark">cairn</span>
			</div>
			<p class="cairn-home__tagline">An agent-native git platform.</p>
			<ul class="cairn-home__links">
				<li><a href="https://forgejo.org/docs/" target="_blank" rel="noopener">Docs</a></li>
				<li><a href="{{AppSubUrl}}/explore/repos">Explore repositories</a></li>
				<li><a href="https://codeberg.org/forgejo/forgejo" target="_blank" rel="noopener">Source</a></li>
			</ul>
		</aside>
		<section class="cairn-home__activity" aria-label="Recent activity">
			<h2>Recent activity</h2>
			<div class="cairn-home__activity-empty">
				Browse <a href="{{AppSubUrl}}/explore/repos">public repositories</a> to see recent commits and agent-attributed work.
			</div>
		</section>
	</div>
</div>
{{template "base/footer" .}}
